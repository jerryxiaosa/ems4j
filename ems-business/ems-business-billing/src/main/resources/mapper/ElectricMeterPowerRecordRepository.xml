<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="info.zhihui.ems.business.billing.repository.ElectricMeterPowerRecordRepository">
    <select id="findRecordList" resultType="info.zhihui.ems.business.billing.entity.ElectricMeterPowerRecordEntity">
        select *
        from energy_electric_meter_power_record
        where is_deleted = 0
        <if test="meterId != null">
          and meter_id = #{meterId}
        </if>
        <if test="accountId != null">
          and account_id = #{accountId}
        </if>
        <if test="beginTime != null">
          and record_time <![CDATA[>=]]> #{beginTime}
        </if>
        <if test="endTime != null">
          and record_time <![CDATA[<=]]> #{endTime}
        </if>
        <choose>
            <when test="asc != null and asc">
                order by record_time asc, id asc
            </when>
            <otherwise>
                order by record_time desc, id desc
            </otherwise>
        </choose>
        <if test="limit != null">
            limit #{limit}
        </if>
    </select>

</mapper>
