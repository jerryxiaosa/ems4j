<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="info.zhihui.ems.business.order.repository.OrderDetailEnergyTopUpRepository">
    
    <select id="selectByOrderSn" resultType="info.zhihui.ems.business.order.entity.OrderDetailEnergyTopUpEntity">
        SELECT *
        FROM order_detail_energy_top_up
        WHERE order_sn = #{orderSn}
        LIMIT 1
    </select>

    <select id="findByOrderSnList" resultType="info.zhihui.ems.business.order.entity.OrderDetailEnergyTopUpEntity">
        SELECT *
        FROM order_detail_energy_top_up
        WHERE order_sn IN
        <foreach collection="orderSnList" item="orderSn" open="(" separator="," close=")">
            #{orderSn}
        </foreach>
    </select>
    
</mapper>
